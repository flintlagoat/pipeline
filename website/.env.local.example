# Inkwell website — copy to `.env.local` and fill from the Supabase dashboard
# (Project Settings → API). No terminal/CLI needed — these are copy-paste from the web UI.
# IMPORTANT: put REAL keys only in `.env.local` (gitignored). This .example file is committed —
# keep placeholders here.

# Project URL + anon (public) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://lundkydfijkkqaaxrvrz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — SERVER ONLY (never NEXT_PUBLIC_). Used by API routes to write leads.
# Keep this secret; it bypasses row-level security.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic — powers the free channel-look demo (/api/demo/channel). Server-only.
# Also add this in the Vercel project's Environment Variables.
ANTHROPIC_API_KEY=sk-ant-...

# Public site URL (used by sitemap.ts). Optional — set to your real domain in production.
NEXT_PUBLIC_SITE_URL=https://inkwell.studio

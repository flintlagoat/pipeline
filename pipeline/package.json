{
  "name": "pipeline",
  "version": "1.0.0",
  "description": "YouTube automation pipeline — spec generator, asset generator, audio, orchestrator",
  "scripts": {
    "watch": "ts-node src/cli.ts watch",
    "channel:new": "ts-node src/cli.ts channel:new",
    "channel:preview": "ts-node src/cli.ts channel:preview",
    "script": "ts-node src/cli.ts script",
    "voiceover": "ts-node src/cli.ts voiceover",
    "process": "ts-node src/cli.ts process",
    "reprocess": "ts-node --transpile-only src/reprocessSpec.ts",
    "thumbnail": "ts-node src/cli.ts thumbnail",
    "approve": "ts-node src/cli.ts approve",
    "status": "ts-node src/cli.ts status",
    "youtube:auth": "ts-node src/cli.ts youtube:auth",
    "publish": "ts-node src/cli.ts publish",
    "analytics:pull": "ts-node src/cli.ts analytics:pull",
    "analytics:analyze": "ts-node src/cli.ts analytics:analyze",
    "autorun": "ts-node src/cli.ts autorun",
    "research": "ts-node src/cli.ts research",
    "test:outliers": "ts-node src/test_outliers.ts",
    "test:pacing": "ts-node src/test_pacing.ts",
    "test:overlap": "ts-node src/test_relayout_overlap.ts",
    "test:schedule": "ts-node src/test_schedule.ts",
    "test:distinct": "ts-node src/test_distinct.ts",
    "typecheck": "tsc --noEmit",
    "ui": "npm --prefix ../ui run build && ts-node src/server.ts",
    "ui:server": "ts-node src/server.ts",
    "test:phase2": "ts-node src/test_specGenerator.ts",
    "test:phase25": "ts-node src/test_assetGenerator.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "multer": "^2.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.41",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}

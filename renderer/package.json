{
  "name": "renderer",
  "version": "1.0.0",
  "description": "YouTube automation board renderer",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:countup": "ts-node --transpile-only src/test_countup.ts",
    "test:camera": "ts-node --transpile-only src/test_camerapath.ts"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.57",
    "@resvg/resvg-js": "^2.6.2",
    "fluent-ffmpeg": "^2.1.3",
    "ffmpeg-static": "^5.2.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
